{
  "manifest_version": 3,
  "name": "股票提醒助手 - 自选股分组与看板",
  "version": "1.0.1",
  "description": "轻量级自选股管理工具：多分组看板、实时行情（新浪+东方财富双数据源）、网格/列表双视图、拖拽排序与置顶、自定义列、智能搜索补全、价格隐藏与涨跌提醒，数据本地存储，隐私安全。",
  "action": {
    "default_title": "股票提醒助手",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://hq.sinajs.cn/*",
    "https://push2.eastmoney.com/*",
    "https://searchapi.eastmoney.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}